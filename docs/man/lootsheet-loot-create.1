.TH LOOTSHEET-LOOT-CREATE 1 "Mar 2026" "LootSheet" "LootSheet Manual"
.SH NAME
lootsheet-loot-create \\- Create a loot register entry
.SH SYNOPSIS
lootsheet loot create [flags]
.SH DESCRIPTION
LootSheet CLI

Usage:
  lootsheet loot create --name TEXT [--source TEXT] [--quantity N] [--holder TEXT] [--notes TEXT]

Examples:
  lootsheet loot create --name "Moonstone" --source "Goblin cave" --quantity 3
  lootsheet loot create --name "Silver chalice" --holder "Brom" --notes "Wrapped in old velvet"
.SH OPTIONS
.TP
-h, --help
help for create
.TP
--holder=string
who is carrying the item (default: )
.TP
--name=string
item name (required) (default: )
.TP
--notes=string
additional notes (default: )
.TP
--quantity=int
item quantity (default: 1)
.TP
--source=string
where the item was found (default: )
.SH SEE ALSO
lootsheet-loot(1)
