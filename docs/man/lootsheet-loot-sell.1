.TH LOOTSHEET-LOOT-SELL 1 "Mar 2026" "LootSheet" "LootSheet Manual"
.SH NAME
lootsheet-loot-sell \\- Record a loot sale
.SH SYNOPSIS
lootsheet loot sell [flags]
.SH DESCRIPTION
LootSheet CLI

Usage:
  lootsheet loot sell --id ID --amount AMOUNT --date YYYY-MM-DD [--description TEXT]

Examples:
  lootsheet loot sell --id loot-123 --amount 55GP --date 2026-03-12
  lootsheet loot sell --id loot-123 --amount 50GP --date 2026-03-12 --description "Sold to dockside broker"
.SH OPTIONS
.TP
--amount=string
sale amount (required) (default: )
.TP
--date=string
sale date in YYYY-MM-DD (required) (default: )
.TP
--description=string
optional description (default: )
.TP
-h, --help
help for sell
.TP
--id=string
loot item ID (required) (default: )
.SH SEE ALSO
lootsheet-loot(1)
